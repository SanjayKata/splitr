# Copy this file to ".env.local" and fill in your Supabase project values.
# These are safe to expose in a static site — the anon key is public by design,
# and row-level security (RLS) is what actually protects your data.
# Used starting in module M1.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Set to "true" only if Supabase "Confirm email" is ON (then the app shows a
# "check your email" step after signup). Leave false/unset to work without emails.
NEXT_PUBLIC_REQUIRE_EMAIL_CONFIRMATION=false

# Public VAPID key for Web Push (from `npx web-push generate-vapid-keys`).
# The private key goes ONLY in the send-push Edge Function's secrets. Leave
# blank to hide the push-notifications toggle.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
